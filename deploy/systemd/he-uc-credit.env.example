# Copy to /etc/he-uc-credit.env and edit values for the server.

# Bind to the Tailscale IP for private-network access.
HE_WEB_HOST=100.84.97.118
HE_WEB_PORT=8080

# Keep this secret. The UI asks for it before upload/status/download calls.
HE_RECEIVER_TOKEN=change-me-long-random-token

# HE jobs are CPU/RAM heavy. Start with one worker and raise after measurement.
HE_WEB_MAX_WORKERS=1
HE_WEB_MAX_UPLOAD_BYTES=536870912
